rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the user is authenticated (not required for this app as per spec "Sem login formal")
    // But we need to prevent users from modifying other people's bets.
    // Since there's no formal login, we can't easily use request.auth.uid.
    // The prompt says: "Sem login formal; o usuário apenas se identifica por nome/apelido".
    // "proibindo deleção ou alteração de palpites alheios"
    // Without auth, anyone can claim to be any userName.
    // To prevent modification, we can just allow create, and deny update/delete.
    
    match /palpites/{palpiteId} {
      // Allow anyone to read
      allow read: if true;
      
      // Allow creation if the document doesn't exist yet and has required fields
      allow create: if 
        request.resource.data.keys().hasAll(['matchId', 'userName', 'guessHome', 'guessAway', 'timestamp']) &&
        request.resource.data.userName is string &&
        request.resource.data.matchId is string &&
        request.resource.data.guessHome is number &&
        request.resource.data.guessAway is number;
        
      // Deny update and delete to prevent altering other people's bets
      allow update, delete: if false;
    }
  }
}
